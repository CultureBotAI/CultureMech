            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:data_quality_flags ] ;
    skos:definition "A complete growth medium formulation for culturing microorganisms. This is the root entity - one per YAML file." ;
    skos:exactMatch culturemech:MediaRecipe ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:MediaTypeDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MediaTypeDescriptor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:term ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:preferred_term ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:MediaDatabaseTerm ;
            owl:onProperty culturemech:term ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:preferred_term ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:preferred_term ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:term ],
        culturemech:Descriptor ;
    skos:definition "Classification and authoritative database reference for the medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:MediaVariant a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MediaVariant" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
