            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:purpose ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:purpose ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:supplier_info ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:modifications ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:purpose ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:SupplierInfo ;
            owl:onProperty culturemech:supplier_info ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:supplier_info ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:modifications ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:EvidenceItem ;
            owl:onProperty culturemech:evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:name ] ;
    skos:definition "A variant or modification of the base recipe" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:MergeMetadata a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MergeMetadata" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
