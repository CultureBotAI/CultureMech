<https://w3id.org/culturemech> a owl:Ontology ;
    rdfs:label "culturemech" ;
    dcterms:license "https://creativecommons.org/publicdomain/zero/1.0/" ;
    dcterms:title "CultureMech - Microbial Growth Media Schema" ;
    skos:definition """LinkML schema for modeling microbial culture media recipes and formulations.
Follows the dismech architecture pattern with descriptor classes for ontology grounding.
""" .

