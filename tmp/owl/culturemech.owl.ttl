culturemech:applications a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "applications" ;
    skos:definition "Use cases and applications" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:biosynthesis_genes a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "biosynthesis_genes" ;
    skos:definition "Genes involved in cofactor biosynthesis" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:categories a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "categories" ;
    skos:definition "All categories this recipe appears in (for cross-category merges)" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Preserves all original category assignments",
        "Used when recipes from different categories are merged based on identical ingredients" .

culturemech:cofactor_requirements a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cofactor_requirements" ;
    skos:definition "Cofactors required by this organism" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:cofactors_provided a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cofactors_provided" ;
    skos:definition "Cofactors supplied by this ingredient" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:community_function a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "community_function" ;
    skos:definition "Specific functional contribution to community" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:community_ids a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "community_ids" ;
    skos:definition "List of CommunityMech IDs this recipe was derived from" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Enables bidirectional linking from CultureMech to CommunityMech",
        "Format CommunityMech:NNNNNN" .

culturemech:community_role a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "community_role" ;
    skos:definition "Functional role in microbial community" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:composition a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "composition" ;
    skos:definition "Ingredients in the stock solution" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:curation_history a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "curation_history" ;
    skos:definition "Audit trail of curation events" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:data_quality_flags a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "data_quality_flags" ;
    skos:definition "Data quality indicators for transparency" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Used to mark recipes with known quality issues",
        "{'Common values': 'incomplete_composition, pending_curation, low_confidence'}" .

culturemech:datasets a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "datasets" ;
    skos:definition "Omics datasets generated using this medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:ec_associations a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ec_associations" ;
    skos:definition "EC numbers of enzymes using this cofactor" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:enzyme_examples a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "enzyme_examples" ;
    skos:definition "Example enzymes requiring this cofactor" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:hierarchy_conflicts a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "hierarchy_conflicts" ;
    skos:definition "Ingredients with conflicting merge signals" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Example \"CaCl2 has multiple parent assignments\"",
        "Used to flag potential quality issues" .

culturemech:ingredients a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ingredients" ;
    skos:definition "Chemical and biological ingredients" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:kegg_pathways a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "kegg_pathways" ;
    skos:definition "KEGG pathway IDs for biosynthesis" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:merged_from a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "merged_from" ;
    skos:definition "Original recipe IDs that were merged into this record" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "List of recipe file IDs that were consolidated into this canonical record",
        "{'Format': 'source_id_sanitized_name (e.g., TOGO_M3236_Luria_Bertani_LB_medium)'}" .

culturemech:modifications a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "modifications" ;
    skos:definition "What differs from base recipe" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:preparation_steps a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "preparation_steps" ;
    skos:definition "Ordered steps to prepare the medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:references a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "references" ;
    skos:definition "Original literature sources" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:role a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "role" ;
    skos:definition "Functional role(s) in the medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:solutions a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "solutions" ;
    skos:definition "Pre-prepared stock solutions used as ingredients" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:substrate_terms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "substrate_terms" ;
    skos:definition "CHEBI terms for substrates" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:substrates a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "substrates" ;
    skos:definition "Transported substrates" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:synonyms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "synonyms" ;
    skos:definition "Alternate names from merged duplicate recipes" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Populated during merge process when duplicate recipes are consolidated",
        "Tracks all non-canonical names with their source provenance" .

culturemech:target_organisms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "target_organisms" ;
    skos:definition "Organisms for which this medium is designed" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:transporters a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "transporters" ;
    skos:definition "Annotated transport systems" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:variants a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "variants" ;
    skos:definition "Related formulations or modifications" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:TemperatureValue a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "TemperatureValue" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:unit ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:TemperatureUnitEnum ;
            owl:onProperty culturemech:unit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:unit ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Float ;
            owl:onProperty culturemech:value ] ;
    skos:definition "Temperature with units" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:aeration a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "aeration" ;
    skos:definition "Gas exchange method (e.g., \"0.5% CO2 in air\", \"bubbling\", \"shaking at 150 rpm\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:authors a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "authors" ;
    skos:definition "Author list" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:bioavailability a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "bioavailability" ;
    skos:definition "Uptake and availability characteristics" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:can_biosynthesize a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "can_biosynthesize" ;
    skos:definition "Whether organism can synthesize this cofactor" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:catalog_number a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "catalog_number" ;
    skos:definition "Product catalog number" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:chemical_fingerprint a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "chemical_fingerprint" ;
    skos:definition "SHA256 hash using parent ingredients (hierarchy-aware)" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Enables smart merging of hydrates, salt forms, and anhydrous variants",
        "Generated only when hierarchy enrichment is available",
        "Treats chemical variants as equivalent (CaCl2·2H2O = CaCl2)",
        "Uses parent CHEBI IDs from MediaIngredientMech hierarchy" .

culturemech:chemical_formula a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "chemical_formula" ;
    skos:definition "Molecular formula (e.g., \"C6H12O6\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:cofactor a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cofactor" ;
    skos:definition "Required cofactor" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:confidence a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "confidence" ;
    skos:definition "Confidence level (0.0-1.0) based on genome annotation" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:container_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "container_type" ;
    skos:definition "Recommended container (e.g., \"glass bottle\", \"polypropylene tube\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:culture_vessel a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "culture_vessel" ;
    skos:definition "Recommended culture container (e.g., \"Erlenmeyer flask\", \"test tube\", \"petri dish\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:curator a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "curator" ;
    skos:definition "Name or identifier of curator" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:dataset_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "dataset_id" ;
    skos:definition "Dataset identifier (GEO, SRA, etc.)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:dataset_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "dataset_type" ;
    skos:definition "Type of omics data (genomics, transcriptomics, metabolomics, etc.)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:direction a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "direction" ;
    skos:definition "Transport direction (import, export, bidirectional)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:ec_number a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ec_number" ;
    skos:definition "EC number if enzymatic" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:equipment a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "equipment" ;
    skos:definition "Required equipment (e.g., \"autoclave\", \"magnetic stirrer\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:explanation a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "explanation" ;
    skos:definition "Why this evidence supports the claim" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:fingerprint_mode a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "fingerprint_mode" ;
    skos:definition "Fingerprinting mode used (chemical/variant/original)" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Enables comparing merge results across modes",
        "Indicates which fingerprint algorithm was used" .

culturemech:fingerprint_version a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "fingerprint_version" ;
    skos:definition "Version of fingerprinting algorithm used" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Enables tracking algorithm changes over time",
        "Example \"hierarchy-chemical-v1.0\" or \"original-v1.0\"",
        "Used to determine which fingerprints are comparable" .

culturemech:growth_phase a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "growth_phase" ;
    skos:definition "Target growth phase (e.g., \"exponential\", \"stationary\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:gtdb_term a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "gtdb_term" ;
    skos:definition "GTDB genome or lineage identifier (alternative to NCBITaxon)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:high_metal a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "high_metal" ;
    skos:definition "Indicates media with total metal concentration above the 90th percentile threshold (≥1049.84 mM). Metals include Fe, Cu, Zn, Mn, Co, Ni, Mo, Se, W, V, Cr, Ca, Mg, K, Na. Based on automated concentration analysis of ingredient composition." ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Threshold computed from distribution of 9,599 media with detectable metal content",
        "Useful for identifying high-metal media for metal toxicity studies or bioremediation applications" .

culturemech:high_ree a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "high_ree" ;
    skos:definition "Indicates media with total rare earth element (REE) concentration above the 90th percentile threshold (≥1030.48 mM). REEs include lanthanides (La, Ce, Pr, Nd, Pm, Sm, Eu, Gd, Tb, Dy, Ho, Er, Tm, Yb, Lu) plus Sc and Y. Based on automated concentration analysis of ingredient composition." ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Threshold computed from distribution of 9,130 media with detectable REE content",
        "Useful for identifying specialized media for REE extraction or bioaccumulation research" .

culturemech:import_date a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "import_date" ;
    skos:definition "Date of import (ISO 8601)" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "ISO 8601 date format YYYY-MM-DD" .

culturemech:incubation_atmosphere a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "incubation_atmosphere" ;
    skos:definition "Atmospheric conditions for incubation" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Imported from CommunityMech when available",
        "Indicates whether the organism requires aerobic, anaerobic, or microaerophilic conditions" .

culturemech:label a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "label" ;
    skos:definition "Ontology term label" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:light_condition a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "light_condition" ;
    skos:definition "Light exposure requirement" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:light_cycle a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "light_cycle" ;
    skos:definition "Photoperiod light:dark cycle (e.g., \"16:8\", \"continuous light\", \"24:0\")" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "For algae and cyanobacteria cultures",
        "{'Format': 'hours_light:hours_dark'}" .

culturemech:light_intensity a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "light_intensity" ;
    skos:definition "Light intensity for photosynthetic organisms (e.g., \"50 µmol photons m⁻² s⁻¹\")" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "For algae and cyanobacteria cultures",
        "{'Common units': 'µE/m²/s, µmol photons m⁻² s⁻¹, lux, or foot-candles'}" .

culturemech:light_quality a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "light_quality" ;
    skos:definition "Light spectrum or wavelength (e.g., \"cool white fluorescent\", \"red LED 660nm\")" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "For algae and cyanobacteria cultures" .

culturemech:media_term a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "media_term" ;
    skos:definition "Reference to authoritative media database" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:mediaingredientmech_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "mediaingredientmech_id" ;
    skos:definition "MediaIngredientMech ID" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:medium_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "medium_type" ;
    skos:definition "Classification of the medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:merge_confidence a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "merge_confidence" ;
    skos:definition "Confidence score for merge decision (0.0-1.0)" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "0.7 = Hydration variant only",
        "0.8 = Same parent ingredients",
        "0.9 = Identical fingerprint",
        "1.0 = Explicit merge rule (highest confidence)" .

culturemech:merge_fingerprint a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "merge_fingerprint" ;
    skos:definition "SHA256 hash of ingredient set for deduplication tracking" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Generated from sorted list of CHEBI IDs and normalized ingredient names",
        "Includes both direct ingredients and solution compositions",
        "Order-independent, concentration-independent" .

culturemech:merge_metadata a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "merge_metadata" ;
    skos:definition "Metadata about merge process and quality" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Enables quality analysis and debugging",
        "Populated during hierarchy-aware merge pipeline",
        "Provides transparency about merge decisions" .

culturemech:merge_mode a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "merge_mode" ;
    skos:definition "Merge mode used (conservative/aggressive/variant-aware)" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "aggressive - Merge all variants with same parent",
        "conservative - Only merge with explicit rules or exact match",
        "variant-aware - Balanced approach, merge some variants" .

culturemech:merge_reason a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "merge_reason" ;
    skos:definition "Why these recipes were merged together" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Indicates which merge rule triggered the merge",
        "Used for quality analysis and debugging" .

culturemech:merge_version a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "merge_version" ;
    skos:definition "Version of merge pipeline used" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Enables tracking pipeline changes",
        "Example \"hierarchy-v1.0\"" .

culturemech:method a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "method" ;
    skos:definition "Sterilization technique" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:modifier a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "modifier" ;
    skos:definition "Modification in variants (INCREASED, DECREASED)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:molecular_weight a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "molecular_weight" ;
    skos:definition "Molecular weight in g/mol" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:organism_culture_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "organism_culture_type" ;
    skos:definition "Whether this medium targets a pure isolate culture or a mixed microbial community" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:origin a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "origin" ;
    skos:definition "Source repository name" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Indicates which X-Mech repository this record was imported from" .

culturemech:original_category a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "original_category" ;
    skos:definition "Original category assignment before merge" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:original_name a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "original_name" ;
    skos:definition "Original name from source database before filename sanitization. May contain special characters like /, :, %, (, ), ', \", <, >, &, #, etc. This field preserves the exact name as it appears in the source database." ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:parent_ingredient a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "parent_ingredient" ;
    skos:definition "Reference to parent chemical entity from MediaIngredientMech" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Example CaCl2·2H2O → parent is \"Calcium chloride\"",
        "Links to canonical parent in MediaIngredientMech hierarchy" .

culturemech:per_volume a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "per_volume" ;
    skos:definition "Volume basis (e.g., \"per liter\", \"per 100 mL\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:ph_range a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ph_range" ;
    skos:definition "Acceptable pH range (e.g., \"6.8-7.2\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:ph_value a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ph_value" ;
    skos:definition "Target pH value" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:physical_state a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "physical_state" ;
    skos:definition "Physical form of the medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:precursor a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "precursor" ;
    skos:definition "Precursor molecule (e.g., thiamine → TPP)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:precursor_term a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "precursor_term" ;
    skos:definition "CHEBI term for precursor" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:preparation_notes a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "preparation_notes" ;
    skos:definition "How to prepare the stock solution" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:pressure a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "pressure" ;
    skos:definition "Pressure in psi or kPa (for autoclaving)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:product_url a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "product_url" ;
    skos:definition "Direct product link" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:purpose a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "purpose" ;
    skos:definition "Why this variant exists" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:salinity a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "salinity" ;
    skos:definition "Salt concentration for marine/brackish media (e.g., \"35 ppt\", \"3.5%\")" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "For marine algae and halophilic organisms" .

culturemech:snippet a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "snippet" ;
    skos:definition "Exact quote from paper (if PMID/DOI available)" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Must be an exact substring of the cited paper's text.",
        "This is automatically validated by the linkml-reference-validator tool." .

culturemech:source a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source" ;
    skos:definition "Source database (KOMODO, MediaDive, TOGO, etc.)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:source_data a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_data" ;
    skos:definition "Provenance tracking for records imported from other repositories" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Preserves bidirectional linking between repositories",
        "Records imported from CommunityMech include community IDs and evidence" .

culturemech:source_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_id" ;
    skos:definition "Original identifier in source database" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:step_number a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "step_number" ;
    skos:definition "Sequential order" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:sterilization a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "sterilization" ;
    skos:definition "Sterilization method and parameters" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:storage a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "storage" ;
    skos:definition "Storage conditions for prepared medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:storage_conditions a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "storage_conditions" ;
    skos:definition "Storage requirements for the stock" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:strain a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "strain" ;
    skos:definition "Specific strain designation (e.g., \"K-12\", \"MG1655\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:supplier_catalog a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supplier_catalog" ;
    skos:definition "Supplier information for sourcing" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:supplier_info a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supplier_info" ;
    skos:definition "Commercial supplier if premix" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:supplier_name a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supplier_name" ;
    skos:definition "Vendor name (e.g., \"Sigma-Aldrich\", \"Thermo Fisher\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:supports a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supports" ;
    skos:definition "Level of support" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:target_abundance a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "target_abundance" ;
    skos:definition "Target relative abundance in community (0.0-1.0)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:temperature_range a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "temperature_range" ;
    skos:definition "Optimal temperature range (e.g., \"20-25°C\", \"room temperature\")" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:temperature_value a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "temperature_value" ;
    skos:definition "Specific culture temperature in Celsius" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:timestamp a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "timestamp" ;
    skos:definition "ISO 8601 timestamp" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:title a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "title" ;
    skos:definition "Publication title" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:transporter_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "transporter_type" ;
    skos:definition "Classification of transporter" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:url a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "url" ;
    skos:definition "Direct link to dataset" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:variant_fingerprint a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "variant_fingerprint" ;
    skos:definition "SHA256 hash preserving variant distinctions" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Generated only when hierarchy enrichment is available",
        "Keeps hydrates separate from anhydrous forms",
        "Preserves important chemical specificity during merge",
        "Uses parent CHEBI + variant type (HYDRATE, ANHYDROUS, SALT_FORM, etc.)" .

culturemech:variant_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "variant_type" ;
    skos:definition "Type of chemical variant" ;
    skos:inScheme <https://w3id.org/culturemech> ;
    skos:note "Describes relationship to parent (HYDRATE, SALT_FORM, ANHYDROUS, etc.)",
        "Populated from MediaIngredientMech metadata" .

culturemech:year a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "year" ;
    skos:definition "Publication year" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:ChemicalEntityTerm a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ChemicalEntityTerm" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^CHEBI:\\d+$" ] ) ] ;
            owl:onProperty culturemech:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:id ],
        culturemech:Term ;
    skos:definition "A CHEBI term representing a chemical entity" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:genes a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:Descriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Descriptor" ;
    skos:definition "Base class for descriptor pattern. Descriptors have a human-readable preferred_term and optional ontology term." ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:OrganismCultureTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/culturemech/OrganismCultureTypeEnum#isolate> <https://w3id.org/culturemech/OrganismCultureTypeEnum#community> ) ;
    linkml:permissible_values <https://w3id.org/culturemech/OrganismCultureTypeEnum#community>,
        <https://w3id.org/culturemech/OrganismCultureTypeEnum#isolate> .

culturemech:EvidenceItem a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "EvidenceItem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:snippet ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:snippet ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:explanation ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:explanation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:snippet ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:supports ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:EvidenceItemSupportEnum ;
            owl:onProperty culturemech:supports ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:explanation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:supports ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:reference ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:reference ] ;
    skos:definition "Evidence supporting a claim about media formulation or performance" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:Term a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Term" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:label ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:id ] ;
    skos:definition "Base class for ontology term references. Subclasses specify id_prefixes for validation." ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:action a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:category a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:concentration a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:duration a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:mediaingredientmech_term a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:reference a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:shelf_life a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:unit a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:value a owl:ObjectProperty,
        linkml:SlotDefinition .

culturemech:AtmosphereEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/culturemech/AtmosphereEnum#AEROBIC> <https://w3id.org/culturemech/AtmosphereEnum#ANAEROBIC> <https://w3id.org/culturemech/AtmosphereEnum#MICROAEROPHILIC> ) ;
    linkml:permissible_values <https://w3id.org/culturemech/AtmosphereEnum#AEROBIC>,
        <https://w3id.org/culturemech/AtmosphereEnum#ANAEROBIC>,
        <https://w3id.org/culturemech/AtmosphereEnum#MICROAEROPHILIC> .

culturemech:LightConditionEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/culturemech/LightConditionEnum#DARK> <https://w3id.org/culturemech/LightConditionEnum#LIGHT_PROTECTED> <https://w3id.org/culturemech/LightConditionEnum#AMBIENT> ) ;
    linkml:permissible_values <https://w3id.org/culturemech/LightConditionEnum#AMBIENT>,
        <https://w3id.org/culturemech/LightConditionEnum#DARK>,
        <https://w3id.org/culturemech/LightConditionEnum#LIGHT_PROTECTED> .

culturemech:ModifierEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/culturemech/ModifierEnum#INCREASED> <https://w3id.org/culturemech/ModifierEnum#DECREASED> <https://w3id.org/culturemech/ModifierEnum#ABSENT> ) ;
    linkml:permissible_values <https://w3id.org/culturemech/ModifierEnum#ABSENT>,
        <https://w3id.org/culturemech/ModifierEnum#DECREASED>,
        <https://w3id.org/culturemech/ModifierEnum#INCREASED> .

culturemech:TemperatureUnitEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( UO:0000027 <https://w3id.org/culturemech/TemperatureUnitEnum#FAHRENHEIT> UO:0000012 ) ;
