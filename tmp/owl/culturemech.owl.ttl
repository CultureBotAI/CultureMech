@prefix NCIT: <http://purl.obolibrary.org/obo/NCIT_> .
@prefix UO: <http://purl.obolibrary.org/obo/UO_> .
@prefix culturemech: <https://w3id.org/culturemech/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

culturemech:CofactorRequirement a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CofactorRequirement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:confidence ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:can_biosynthesize ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:can_biosynthesize ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:genes ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:cofactor ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Boolean ;
            owl:onProperty culturemech:can_biosynthesize ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:evidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Float ;
            owl:onProperty culturemech:confidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:genes ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:CofactorDescriptor ;
            owl:onProperty culturemech:cofactor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:cofactor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:confidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:EvidenceItem ;
            owl:onProperty culturemech:evidence ] ;
    skos:definition "Cofactor requirement for an organism" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:CurationEvent a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CurationEvent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:action ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:timestamp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:action ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:action ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:curator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:timestamp ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:curator ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:curator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:timestamp ] ;
    skos:definition "Audit trail entry for curation" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:Dataset a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Dataset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:dataset_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:dataset_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:url ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Uri ;
            owl:onProperty culturemech:url ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:dataset_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:dataset_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:dataset_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:dataset_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:url ] ;
    skos:definition "Omics dataset generated using this medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:GTDBTerm a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "GTDBTerm" ;
    rdfs:subClassOf culturemech:Term ;
    skos:definition "A GTDB genome identifier. id = GTDB accession (e.g. GTDB:RS_GCF_000006945.2), label = full GTDB lineage string (e.g. d__Bacteria;p__Proteobacteria;...)" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:IngredientReference a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "IngredientReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:preferred_term ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:String [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^MediaIngredientMech:\\d{6}$" ] ) ] ) ] ;
            owl:onProperty culturemech:mediaingredientmech_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:preferred_term ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:mediaingredientmech_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:preferred_term ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:mediaingredientmech_id ] ;
    skos:definition "Reference to canonical ingredient" ;
    skos:inScheme <https://w3id.org/culturemech> .

culturemech:MediaDatabaseTerm a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MediaDatabaseTerm" ;
    rdfs:subClassOf culturemech:Term ;
    skos:definition "Identifier from authoritative media database" ;
    skos:inScheme <https://w3id.org/culturemech> .

