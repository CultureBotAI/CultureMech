culturemech:StorageConditions a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "StorageConditions" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:container_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:light_condition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:container_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:shelf_life ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:TemperatureValue ;
            owl:onProperty culturemech:temperature ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:light_condition ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:temperature ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty culturemech:temperature ],
        [ a owl:Restriction ;
            owl:allValuesFrom culturemech:LightConditionEnum ;
            owl:onProperty culturemech:light_condition ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty culturemech:shelf_life ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty culturemech:container_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty culturemech:shelf_life ] ;
    skos:definition "Storage requirements for prepared medium" ;
    skos:inScheme <https://w3id.org/culturemech> .

