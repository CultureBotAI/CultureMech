          "range": "Dataset",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "curation_history",
          "description": "Audit trail of curation events",
          "range": "CurationEvent",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "data_quality_flags",
          "description": "Data quality indicators for transparency",
          "comments": [
            "Used to mark recipes with known quality issues",
            "{'Common values': 'incomplete_composition, pending_curation, low_confidence'}"
          ],
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "incubation_atmosphere",
          "description": "Atmospheric conditions for incubation",
          "comments": [
            "Indicates whether the organism requires aerobic, anaerobic, or microaerophilic conditions",
            "Imported from CommunityMech when available"
          ],
          "range": "AtmosphereEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "source_data",
          "description": "Provenance tracking for records imported from other repositories",
          "comments": [
            "Records imported from CommunityMech include community IDs and evidence",
            "Preserves bidirectional linking between repositories"
          ],
          "range": "SourceData",
          "inlined": true,
          "@type": "SlotDefinition"
        }
