      "slot_usage": {},
      "attributes": [
        {
          "name": "name",
          "description": "Human-readable medium name (e.g., \"LB Broth\", \"M9 Minimal Medium\")",
          "identifier": true,
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "original_name",
          "description": "Original name from source database before filename sanitization. May contain special characters like /, :, %, (, ), ', \", <, >, &, #, etc. This field preserves the exact name as it appears in the source database.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "category",
          "description": "Broad category for organization",
          "range": "CategoryEnum",
          "recommended": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "categories",
          "description": "All categories this recipe appears in (for cross-category merges)",
          "comments": [
            "Used when recipes from different categories are merged based on identical ingredients",
            "Preserves all original category assignments"
          ],
          "range": "CategoryEnum",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "high_metal",
          "description": "Indicates media with total metal concentration above the 90th percentile threshold (\u22651049.84 mM). Metals include Fe, Cu, Zn, Mn, Co, Ni, Mo, Se, W, V, Cr, Ca, Mg, K, Na. Based on automated concentration analysis of ingredient composition.",
          "comments": [
            "Threshold computed from distribution of 9,599 media with detectable metal content",
            "Useful for identifying high-metal media for metal toxicity studies or bioremediation applications"
          ],
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "high_ree",
          "description": "Indicates media with total rare earth element (REE) concentration above the 90th percentile threshold (\u22651030.48 mM). REEs include lanthanides (La, Ce, Pr, Nd, Pm, Sm, Eu, Gd, Tb, Dy, Ho, Er, Tm, Yb, Lu) plus Sc and Y. Based on automated concentration analysis of ingredient composition.",
          "comments": [
            "Threshold computed from distribution of 9,130 media with detectable REE content",
            "Useful for identifying specialized media for REE extraction or bioaccumulation research"
          ],
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "synonyms",
          "description": "Alternate names from merged duplicate recipes",
          "comments": [
            "Populated during merge process when duplicate recipes are consolidated",
            "Tracks all non-canonical names with their source provenance"
          ],
          "range": "RecipeSynonym",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "merged_from",
          "description": "Original recipe IDs that were merged into this record",
          "comments": [
            "List of recipe file IDs that were consolidated into this canonical record",
            "{'Format': 'source_id_sanitized_name (e.g., TOGO_M3236_Luria_Bertani_LB_medium)'}"
          ],
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "merge_fingerprint",
          "description": "SHA256 hash of ingredient set for deduplication tracking",
          "comments": [
            "Generated from sorted list of CHEBI IDs and normalized ingredient names",
            "Includes both direct ingredients and solution compositions",
            "Order-independent, concentration-independent"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "chemical_fingerprint",
          "description": "SHA256 hash using parent ingredients (hierarchy-aware)",
          "comments": [
            "Treats chemical variants as equivalent (CaCl2\u00b72H2O = CaCl2)",
            "Uses parent CHEBI IDs from MediaIngredientMech hierarchy",
            "Enables smart merging of hydrates, salt forms, and anhydrous variants",
            "Generated only when hierarchy enrichment is available"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "variant_fingerprint",
          "description": "SHA256 hash preserving variant distinctions",
          "comments": [
            "Keeps hydrates separate from anhydrous forms",
            "Uses parent CHEBI + variant type (HYDRATE, ANHYDROUS, SALT_FORM, etc.)",
            "Preserves important chemical specificity during merge",
            "Generated only when hierarchy enrichment is available"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "fingerprint_version",
          "description": "Version of fingerprinting algorithm used",
          "comments": [
            "Example \"hierarchy-chemical-v1.0\" or \"original-v1.0\"",
            "Enables tracking algorithm changes over time",
            "Used to determine which fingerprints are comparable"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "merge_metadata",
          "description": "Metadata about merge process and quality",
          "comments": [
            "Provides transparency about merge decisions",
            "Enables quality analysis and debugging",
            "Populated during hierarchy-aware merge pipeline"
          ],
          "range": "MergeMetadata",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "media_term",
          "description": "Reference to authoritative media database",
          "range": "MediaTypeDescriptor",
          "recommended": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "description",
          "description": "Overview of the medium and its purpose",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "target_organisms",
          "description": "Organisms for which this medium is designed",
          "range": "OrganismDescriptor",
          "recommended": true,
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "organism_culture_type",
          "description": "Whether this medium targets a pure isolate culture or a mixed microbial community",
          "range": "OrganismCultureTypeEnum",
          "recommended": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "medium_type",
          "description": "Classification of the medium",
          "range": "MediumTypeEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "physical_state",
          "description": "Physical form of the medium",
          "range": "PhysicalStateEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "ph_value",
          "description": "Target pH value",
          "range": "float",
          "@type": "SlotDefinition"
        },
        {
          "name": "ph_range",
          "description": "Acceptable pH range (e.g., \"6.8-7.2\")",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "light_intensity",
          "description": "Light intensity for photosynthetic organisms (e.g., \"50 \u00b5mol photons m\u207b\u00b2 s\u207b\u00b9\")",
          "comments": [
            "For algae and cyanobacteria cultures",
            "{'Common units': '\u00b5E/m\u00b2/s, \u00b5mol photons m\u207b\u00b2 s\u207b\u00b9, lux, or foot-candles'}"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "light_cycle",
          "description": "Photoperiod light:dark cycle (e.g., \"16:8\", \"continuous light\", \"24:0\")",
          "comments": [
            "For algae and cyanobacteria cultures",
            "{'Format': 'hours_light:hours_dark'}"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "light_quality",
          "description": "Light spectrum or wavelength (e.g., \"cool white fluorescent\", \"red LED 660nm\")",
          "comments": [
            "For algae and cyanobacteria cultures"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "temperature_range",
          "description": "Optimal temperature range (e.g., \"20-25\u00b0C\", \"room temperature\")",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "temperature_value",
          "description": "Specific culture temperature in Celsius",
          "range": "float",
          "@type": "SlotDefinition"
        },
        {
          "name": "salinity",
          "description": "Salt concentration for marine/brackish media (e.g., \"35 ppt\", \"3.5%\")",
          "comments": [
            "For marine algae and halophilic organisms"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "aeration",
          "description": "Gas exchange method (e.g., \"0.5% CO2 in air\", \"bubbling\", \"shaking at 150 rpm\")",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "culture_vessel",
          "description": "Recommended culture container (e.g., \"Erlenmeyer flask\", \"test tube\", \"petri dish\")",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "ingredients",
          "description": "Chemical and biological ingredients",
          "range": "IngredientDescriptor",
          "required": true,
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "solutions",
          "description": "Pre-prepared stock solutions used as ingredients",
          "range": "SolutionDescriptor",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "preparation_steps",
          "description": "Ordered steps to prepare the medium",
          "range": "PreparationStep",
          "recommended": true,
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "sterilization",
          "description": "Sterilization method and parameters",
          "range": "SterilizationDescriptor",
          "recommended": true,
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "storage",
          "description": "Storage conditions for prepared medium",
          "range": "StorageConditions",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "applications",
          "description": "Use cases and applications",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "variants",
          "description": "Related formulations or modifications",
          "range": "MediaVariant",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "references",
          "description": "Original literature sources",
          "range": "PublicationReference",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "notes",
          "description": "Additional context, historical notes, tips",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "evidence",
          "description": "Evidence supporting formulation claims",
          "range": "EvidenceItem",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "datasets",
