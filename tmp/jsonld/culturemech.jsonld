    {
      "name": "MergeMetadata",
      "definition_uri": "https://w3id.org/culturemech/MergeMetadata",
      "description": "Metadata about merge process and quality",
      "from_schema": "https://w3id.org/culturemech",
      "slots": [
        "mergeMetadata__merge_version",
        "mergeMetadata__merge_mode",
        "mergeMetadata__merge_reason",
        "mergeMetadata__merge_confidence",
        "mergeMetadata__hierarchy_conflicts",
        "mergeMetadata__fingerprint_mode"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "merge_version",
          "description": "Version of merge pipeline used",
          "comments": [
            "Example \"hierarchy-v1.0\"",
            "Enables tracking pipeline changes"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "merge_mode",
          "description": "Merge mode used (conservative/aggressive/variant-aware)",
          "comments": [
            "conservative - Only merge with explicit rules or exact match",
            "aggressive - Merge all variants with same parent",
            "variant-aware - Balanced approach, merge some variants"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "merge_reason",
          "description": "Why these recipes were merged together",
          "comments": [
            "Indicates which merge rule triggered the merge",
            "Used for quality analysis and debugging"
          ],
          "range": "MergeReasonEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "merge_confidence",
          "description": "Confidence score for merge decision (0.0-1.0)",
          "comments": [
            "1.0 = Explicit merge rule (highest confidence)",
            "0.9 = Identical fingerprint",
            "0.8 = Same parent ingredients",
            "0.7 = Hydration variant only"
          ],
          "range": "float",
          "@type": "SlotDefinition"
        },
        {
          "name": "hierarchy_conflicts",
          "description": "Ingredients with conflicting merge signals",
          "comments": [
            "Used to flag potential quality issues",
            "Example \"CaCl2 has multiple parent assignments\""
          ],
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "fingerprint_mode",
          "description": "Fingerprinting mode used (chemical/variant/original)",
          "comments": [
            "Indicates which fingerprint algorithm was used",
            "Enables comparing merge results across modes"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/culturemech/MergeMetadata",
      "@type": "ClassDefinition"
    },
